{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DspChainOutput",
  "description": "DSP chain output (AudioEngine PluginConfig format)",
  "type": "object",
  "properties": {
    "version": {
      "description": "Output version",
      "type": "string",
      "default": "1.4.0"
    },
    "channels": {
      "description": "Per-channel DSP chains",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/ChannelDspChain"
      }
    },
    "metadata": {
      "description": "Metadata about the optimization",
      "anyOf": [
        {
          "$ref": "#/$defs/OptimizationMetadata"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "channels"
  ],
  "$defs": {
    "ChannelDspChain": {
      "description": "DSP chain for a single channel",
      "type": "object",
      "properties": {
        "channel": {
          "description": "Channel name",
          "type": "string"
        },
        "plugins": {
          "description": "Ordered list of plugins (AudioEngine PluginConfig format)",
          "type": "array",
          "items": {
            "$ref": "#/$defs/PluginConfigWrapper"
          }
        },
        "drivers": {
          "description": "Per-driver DSP chains for active crossover (optional)",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/DriverDspChain"
          }
        },
        "initial_curve": {
          "description": "Initial frequency response curve before optimization (optional)",
          "anyOf": [
            {
              "$ref": "#/$defs/CurveData"
            },
            {
              "type": "null"
            }
          ]
        },
        "final_curve": {
          "description": "Final frequency response curve after applying correction (optional)",
          "anyOf": [
            {
              "$ref": "#/$defs/CurveData"
            },
            {
              "type": "null"
            }
          ]
        },
        "eq_response": {
          "description": "EQ filter response curve (correction magnitude in dB) (optional)",
          "anyOf": [
            {
              "$ref": "#/$defs/CurveData"
            },
            {
              "type": "null"
            }
          ]
        },
        "target_curve": {
          "description": "Effective target curve the optimizer worked against (optional).\nThis is the mean-shifted + tilt target in absolute SPL coordinates,\nso the frontend can display what the optimizer was actually aiming for.",
          "anyOf": [
            {
              "$ref": "#/$defs/CurveData"
            },
            {
              "type": "null"
            }
          ]
        },
        "pre_ir": {
          "description": "Impulse response before correction (optional, requires phase data)",
          "anyOf": [
            {
              "$ref": "#/$defs/IrWaveform"
            },
            {
              "type": "null"
            }
          ]
        },
        "post_ir": {
          "description": "Impulse response after correction (optional, requires phase data)",
          "anyOf": [
            {
              "$ref": "#/$defs/IrWaveform"
            },
            {
              "type": "null"
            }
          ]
        },
        "fir_temporal_masking": {
          "description": "FIR impulse-response temporal masking metrics (optional, FIR/phase modes)",
          "anyOf": [
            {
              "$ref": "#/$defs/TemporalIrMaskingMetrics"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "channel",
        "plugins"
      ]
    },
    "PluginConfigWrapper": {
      "description": "Wrapper for AudioEngine PluginConfig (re-exported from src-audio)",
      "type": "object",
      "properties": {
        "plugin_type": {
          "type": "string"
        },
        "parameters": true
      },
      "required": [
        "plugin_type",
        "parameters"
      ]
    },
    "DriverDspChain": {
      "description": "DSP chain for an individual driver in a multi-driver speaker",
      "type": "object",
      "properties": {
        "name": {
          "description": "Driver name (e.g., \"woofer\", \"tweeter\")",
          "type": "string"
        },
        "index": {
          "description": "Driver index in the array (0 = lowest frequency)",
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "plugins": {
          "description": "Ordered list of plugins for this driver (gain, crossover filters)",
          "type": "array",
          "items": {
            "$ref": "#/$defs/PluginConfigWrapper"
          }
        },
        "initial_curve": {
          "description": "Initial frequency response curve for this driver before optimization (optional)",
          "anyOf": [
            {
              "$ref": "#/$defs/CurveData"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "name",
        "index",
        "plugins"
      ]
    },
    "CurveData": {
      "description": "Frequency response curve data for serialization\n\nRepresents a curve with frequency points and SPL values.\nSPL values are normalized (mean-subtracted in the 1000-2000 Hz range)\nfor consistent comparison across measurements.",
      "type": "object",
      "properties": {
        "freq": {
          "description": "Frequency points in Hz",
          "type": "array",
          "items": {
            "type": "number",
            "format": "double"
          }
        },
        "spl": {
          "description": "Sound Pressure Level in dB (normalized)",
          "type": "array",
          "items": {
            "type": "number",
            "format": "double"
          }
        },
        "phase": {
          "description": "Phase in degrees (optional)",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "number",
            "format": "double"
          }
        },
        "norm_range": {
          "description": "Optional frequency range used for normalization",
          "type": [
            "array",
            "null"
          ],
          "prefixItems": [
            {
              "type": "number",
              "format": "double"
            },
            {
              "type": "number",
              "format": "double"
            }
          ],
          "minItems": 2,
          "maxItems": 2
        }
      },
      "required": [
        "freq",
        "spl"
      ]
    },
    "IrWaveform": {
      "description": "Impulse response waveform (time-domain)",
      "type": "object",
      "properties": {
        "time_ms": {
          "description": "Time axis in milliseconds",
          "type": "array",
          "items": {
            "type": "number",
            "format": "double"
          }
        },
        "amplitude": {
          "description": "Amplitude (normalized so pre-IR peak = 1.0)",
          "type": "array",
          "items": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "required": [
        "time_ms",
        "amplitude"
      ]
    },
    "OptimizationMetadata": {
      "description": "Optimization metadata",
      "type": "object",
      "properties": {
        "pre_score": {
          "description": "Pre-optimization score",
          "type": "number",
          "format": "double"
        },
        "post_score": {
          "description": "Post-optimization score",
          "type": "number",
          "format": "double"
        },
        "algorithm": {
          "description": "Optimization algorithm used",
          "type": "string"
        },
        "iterations": {
          "description": "Number of iterations",
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "timestamp": {
          "description": "Timestamp",
          "type": "string"
        },
        "inter_channel_deviation": {
          "description": "Inter-channel deviation metric (computed when >1 channel)",
          "anyOf": [
            {
              "$ref": "#/$defs/InterChannelDeviation"
            },
            {
              "type": "null"
            }
          ]
        },
        "perceptual_metrics": {
          "description": "Perceptual scorecard computed from final exported curves/DSP.",
          "anyOf": [
            {
              "$ref": "#/$defs/PerceptualMetrics"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "pre_score",
        "post_score",
        "algorithm",
        "iterations",
        "timestamp"
      ]
    },
    "PerceptualMetrics": {
      "description": "Compact perceptual scorecard for downstream QA and UIs.",
      "type": "object",
      "properties": {
        "epa_preference_pre": {
          "description": "Average EPA preference before correction.",
          "type": "number",
          "format": "double"
        },
        "epa_preference_post": {
          "description": "Average EPA preference after correction.",
          "type": "number",
          "format": "double"
        },
        "epa_preference_delta": {
          "description": "EPA preference delta, positive means perceptual improvement.",
          "type": "number",
          "format": "double"
        },
        "fir_pre_ringing_audible_db": {
          "description": "Maximum FIR pre-ringing audible energy across channels, dB relative to each FIR's main impulse peak.",
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "fir_post_ringing_audible_db": {
          "description": "Maximum FIR post-ringing audible energy across channels, dB relative to each FIR's main impulse peak.",
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "fir_temporal_masking_penalty": {
          "description": "Maximum FIR temporal masking penalty across channels.",
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        }
      },
      "required": [
        "epa_preference_pre",
        "epa_preference_post",
        "epa_preference_delta"
      ]
    },
    "TemporalIrMaskingMetrics": {
      "description": "True impulse-response temporal masking metrics for FIR / phase correction.",
      "type": "object",
      "properties": {
        "main_index": {
          "description": "Main impulse sample index used as the transient reference.",
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "main_time_ms": {
          "description": "Main impulse time in milliseconds from the start of the FIR.",
          "type": "number",
          "format": "double"
        },
        "pre_ringing_peak_db": {
          "description": "Peak pre-ringing level before the main impulse, dB relative to main.",
          "type": "number",
          "format": "double"
        },
        "post_ringing_peak_db": {
          "description": "Peak post-ringing level after the main impulse, dB relative to main.",
          "type": "number",
          "format": "double"
        },
        "pre_ringing_audible_db": {
          "description": "Pre-masked audible pre-ringing energy, dB relative to main peak energy.",
          "type": "number",
          "format": "double"
        },
        "post_ringing_audible_db": {
          "description": "Post-masked audible post-ringing energy, dB relative to main peak energy.",
          "type": "number",
          "format": "double"
        },
        "penalty": {
          "description": "Scalar penalty using the configured material profile and IR weights.",
          "type": "number",
          "format": "double"
        }
      },
      "required": [
        "main_index",
        "main_time_ms",
        "pre_ringing_peak_db",
        "post_ringing_peak_db",
        "pre_ringing_audible_db",
        "post_ringing_audible_db",
        "penalty"
      ]
    },
    "InterChannelDeviation": {
      "description": "Measurement of inter-channel SPL consistency after optimization.\n\nAt each frequency, the max-min spread across all channels is computed.\nRMS and peak statistics summarize the deviation in key frequency bands.",
      "type": "object",
      "properties": {
        "deviation_per_freq": {
          "description": "Per-frequency max deviation (freq_hz, spread_db) — sampled at measurement points",
          "type": "array",
          "items": {
            "type": "array",
            "prefixItems": [
              {
                "type": "number",
                "format": "double"
              },
              {
                "type": "number",
                "format": "double"
              }
            ],
            "minItems": 2,
            "maxItems": 2
          }
        },
        "midrange_rms_db": {
          "description": "RMS of deviation in the midrange (200-4000 Hz)",
          "type": "number",
          "format": "double"
        },
        "passband_rms_db": {
          "description": "RMS of deviation from F3 to 10 kHz",
          "type": "number",
          "format": "double"
        },
        "midrange_peak_db": {
          "description": "Maximum single-point deviation in midrange",
          "type": "number",
          "format": "double"
        },
        "midrange_peak_freq": {
          "description": "Frequency of maximum midrange deviation",
          "type": "number",
          "format": "double"
        }
      },
      "required": [
        "deviation_per_freq",
        "midrange_rms_db",
        "passband_rms_db",
        "midrange_peak_db",
        "midrange_peak_freq"
      ]
    }
  }
}
