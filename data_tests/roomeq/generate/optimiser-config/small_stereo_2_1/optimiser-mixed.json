{
  "speakers": {
    "left0": "left_lp0.csv",
    "right0": "right_lp0.csv",
    "sub0": "subwoofer_lp0.csv"
  },
  "system": {
    "model": "stereo",
    "speakers": {
      "L": "left0",
      "R": "right0",
      "LFE": "sub0"
    },
    "subwoofers": {
      "config": "single",
      "sub0": "L",
      "crossover": "first"
    }
  },
  "optimizer": {
    "mode": "mixed",
    "loss_type": "flat",
    "fir": {
      "taps": 4096,
      "phase": "kirkeby"
    },
    "loss_type": "flat",
    "algorithm": "autoeq:de",
    "num_filters": 9,
    "min_q": 0.5,
    "max_q": 6.0,
    "min_db": -12.0,
    "max_db": 8.0,
    "min_freq": 20.0,
    "max_freq": 16000.0,
    "max_iter": 25000,
    "population": 40,
    "peq_model": "pk",
    "seed": 42,
    "refine": true,
    "local_algo": "cobyla",
    "psychoacoustic": true,
    "asymmetric_loss": true
  },
  "crossovers": {
    "first": {
      "type": "LR48",
      "frequency_range": [60,150]
    }
  }
}
