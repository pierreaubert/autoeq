# Multi-stage build: Builder stage
FROM ubuntu:24.04 AS builder

ARG DEBIAN_FRONTEND=noninteractive

# Combine all package updates into single layer to reduce image size
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    curl \
    git \
    build-essential \
    gcc \
    g++ \
    pkg-config \
    libssl-dev \
    libsqlite3-dev \
    ca-certificates \
    cmake \
    ninja-build \
    perl \
    libglib2.0-dev \
    libgtk-3-dev \
    libwebkit2gtk-4.1-dev \
    libayatana-appindicator3-dev \
    librsvg2-dev \
    patchelf \
    libopenblas-dev \
    gfortran \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# Install Rust (pinned for reproducibility)
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | \
    sh -s -- -y --default-toolchain 1.90.0 --profile minimal && \
    rm -rf /root/.cargo/registry /root/.cargo/git

ENV PATH="/root/.cargo/bin:${PATH}"

# Install rustup target and just
RUN rustup target add x86_64-unknown-linux-gnu && \
    cargo install just --locked && \
    rm -rf /root/.cargo/registry /root/.cargo/git

# Configure build environment
ENV PKG_CONFIG_PATH=/usr/lib/x86_64-linux-gnu/pkgconfig:/usr/share/pkgconfig
ENV PKG_CONFIG_ALLOW_CROSS=1
ENV OPENSSL_STATIC=1
ENV OPENSSL_VENDORED=1
ENV CARGO_NET_GIT_FETCH_WITH_CLI=true

WORKDIR /project

# Copy source with .dockerignore in place (excludes target/, .git, etc.)
COPY . .

# Build release binary (adjust APP_NAME if needed)
RUN cargo build --release --target x86_64-unknown-linux-gnu && \
    find target/x86_64-unknown-linux-gnu/release -maxdepth 1 -type f -executable | xargs strip -v 2>/dev/null || true && \
    rm -rf target/.rustc_info.json target/.fingerprint target/x86_64-unknown-linux-gnu/release/deps/*.d
