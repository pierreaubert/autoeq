# Multi-stage build: Builder stage
FROM ubuntu:24.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Etc/UTC

# Install build dependencies - combined into single layer
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    curl \
    git \
    build-essential \
    gcc \
    g++ \
    pkg-config \
    ca-certificates \
    cmake \
    ninja-build \
    perl \
    zip \
    openssl \
    osslsigncode \
    libxml2-utils \
    libssl-dev \
    mingw-w64 \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# Install Rust 1.95 (pinned version for compatibility)
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | \
    sh -s -- -y --default-toolchain 1.95.0 --profile minimal && \
    rm -rf /root/.cargo/registry /root/.cargo/git

ENV PATH="/root/.cargo/bin:${PATH}"
# Keep Docker builds on the pinned toolchain even when the mounted workspace
# contains rust-toolchain.toml with channel = "stable".
ENV RUSTUP_TOOLCHAIN=1.95.0

# Add the Windows target
RUN rustup target add --toolchain 1.95.0 x86_64-pc-windows-gnullvm

# Install just
RUN cargo install just --locked && \
    rm -rf /root/.cargo/registry /root/.cargo/git

ARG LLVM_MINGW_VERSION=20260421
ARG LLVM_MINGW_CRT=ucrt
ARG LLVM_MINGW_UBUNTU=22.04
ARG LLVM_MINGW_HOST=x86_64

# Keep the x86_64 gnullvm image on the same LLVM-MinGW toolchain family as
# Windows ARM64, instead of mixing GNU binutils with the gnullvm target.
RUN curl -fsSL "https://github.com/mstorsjo/llvm-mingw/releases/download/${LLVM_MINGW_VERSION}/llvm-mingw-${LLVM_MINGW_VERSION}-${LLVM_MINGW_CRT}-ubuntu-${LLVM_MINGW_UBUNTU}-${LLVM_MINGW_HOST}.tar.xz" | \
    tar -xJ -C /opt && \
    mv "/opt/llvm-mingw-${LLVM_MINGW_VERSION}-${LLVM_MINGW_CRT}-ubuntu-${LLVM_MINGW_UBUNTU}-${LLVM_MINGW_HOST}" /opt/llvm-mingw

ENV PATH="/opt/llvm-mingw/bin:${PATH}"
ENV CC_x86_64_pc_windows_gnullvm=x86_64-w64-mingw32-clang
ENV CXX_x86_64_pc_windows_gnullvm=x86_64-w64-mingw32-clang++
ENV AR_x86_64_pc_windows_gnullvm=x86_64-w64-mingw32-ar
ENV CARGO_TARGET_X86_64_PC_WINDOWS_GNULLVM_LINKER=x86_64-w64-mingw32-clang
ENV CARGO_TARGET_X86_64_PC_WINDOWS_GNULLVM_AR=x86_64-w64-mingw32-ar

WORKDIR /project

# Copy source with .dockerignore in place
COPY . .

# Build the Windows release artifact used by the packaging recipe.
RUN cargo build --release --target x86_64-pc-windows-gnullvm -p sotf-tui --bin sotf-tui && \
    (x86_64-w64-mingw32-strip -v target/x86_64-pc-windows-gnullvm/release/sotf-tui.exe 2>/dev/null || true) && \
    rm -rf target/.rustc_info.json target/.fingerprint target/x86_64-pc-windows-gnullvm/release/deps/*.d
