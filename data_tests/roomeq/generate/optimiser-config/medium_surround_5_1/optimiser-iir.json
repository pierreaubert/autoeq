{
  "version": "1.2.0",
  "system": {
    "model": "home_cinema",
    "speakers": {
      "SL": "surround_left",
      "SR": "surround_right",
      "R": "right",
      "L": "left",
      "C": "center",
      "LFE": "lfe"
    },
    "subwoofers": {
      "config": "single",
      "crossover": "first",
      "lfe": "L"
    }
  },
  "speakers": {
    "left": "left_lp0.csv",
    "right": "right_lp0.csv",
    "surround_right": "surround_right_lp0.csv",
    "lfe": "subwoofer_lp0.csv",
    "surround_left": "surround_left_lp0.csv",
    "center": "center_lp0.csv"
  },
  "crossovers": {
    "first": {
      "type": "LR24",
      "frequency": 80.0
    }
  },
  "optimizer": {
    "mode": "iir",
    "processing_mode": "low_latency",
    "loss_type": "flat",
    "target_tilt": {
      "tilt_type": "custom",
      "slope_db_per_octave": -0.8,
      "reference_freq": 1000,
      "bass_shelf_db": 3.0,
      "bass_shelf_freq": 150
    },
    "broadband_target_matching": {
      "enabled": true
    },
    "excursion_protection": {
      "enabled": true,
      "auto_detect_f3": true,
      "filter_order": 4,
      "filter_type": "linkwitzriley",
      "margin_octaves": 0.25
    },
    "schroeder_split": {
      "enabled": true,
      "schroeder_freq": 400,
      "low_freq_config": {
        "max_q": 10.0,
        "min_q": 0.5,
        "allow_boost": false
      },
      "high_freq_config": {
        "max_q": 1.0,
        "shelving_only": false
      }
    },
    "phase_alignment": {
      "enabled": true,
      "min_freq": 60,
      "max_freq": 100,
      "optimize_polarity": true,
      "max_delay_ms": 30
    },
    "algorithm": "autoeq:de",
    "num_filters": 7,
    "min_q": 0.5,
    "max_q": 6.0,
    "min_db": -30.0,
    "max_db": 24.0,
    "min_freq": 20.0,
    "max_freq": 16000.0,
    "max_iter": 25000,
    "population": 50,
    "peq_model": "pk",
    "seed": 42,
    "refine": true,
    "local_algo": "cobyla",
    "psychoacoustic": true,
    "asymmetric_loss": true
  },
  "group_delay": [
    {
      "subwoofer": "lfe",
      "speakers": ["left"],
      "min_freq": 30.0,
      "max_freq": 120.0
    }
  ]
}
