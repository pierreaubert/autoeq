# Multi-stage build: Builder stage
FROM --platform=linux/arm64 ubuntu:24.04 AS builder

ARG DEBIAN_FRONTEND=noninteractive

# Install base build dependencies - combined into single layer
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    curl \
    git \
    build-essential \
    gcc \
    g++ \
    pkg-config \
    ca-certificates \
    cmake \
    ninja-build \
    perl \
    libglib2.0-dev \
    libxkbcommon-x11-dev \
    libgtk-3-dev \
    libwebkit2gtk-4.1-dev \
    libayatana-appindicator3-dev \
    librsvg2-dev \
    libasound2-dev \
    libclang-dev \
    libssl-dev \
    libsqlite3-dev \
    patchelf \
    gnome-browser-connector \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# Install Rust 1.95 (pinned version for compatibility)
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | \
    sh -s -- -y --default-toolchain 1.95.0 --profile minimal && \
    rm -rf /root/.cargo/registry /root/.cargo/git

ENV PATH="/root/.cargo/bin:${PATH}"

# Add the target
RUN rustup target add aarch64-unknown-linux-gnu

# Install just
RUN cargo install just --locked && \
    rm -rf /root/.cargo/registry /root/.cargo/git

# Repair rustup state
RUN rustup component remove clippy 2>/dev/null; rustup component add clippy

WORKDIR /project

# Copy source with .dockerignore in place
COPY . .

# Build release binary
RUN cargo build --release --target aarch64-unknown-linux-gnu && \
    (find target/aarch64-unknown-linux-gnu/release -maxdepth 1 -type f -executable | xargs strip -v 2>/dev/null || true) && \
    rm -rf target/.rustc_info.json target/.fingerprint target/aarch64-unknown-linux-gnu/release/deps/*.d
